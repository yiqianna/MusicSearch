# Copy to .env.local and fill from Firebase Console → Project settings → Your apps.
# Enable Authentication → Sign-in method → Google.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ---------- Free deploy (default) ----------
# Production build (see .env.production): no proxy → browser → iTunes directly.
# Firebase Hosting Spark only: npm run deploy (from repo root).
#
# If iTunes is blocked for your users: free Cloudflare Worker + Wrangler:
#   cd frontend && npx wrangler deploy
# Then in .env.production.local (gitignored):
# VITE_ITUNES_API_BASE=https://YOUR_SUBDOMAIN.workers.dev
# VITE_ARTWORK_PROXY=https://YOUR_SUBDOMAIN.workers.dev/image

# Optional: custom HTTPS proxy (no trailing slash)
# VITE_ITUNES_API_BASE=

# Optional: image proxy with ?url=
# VITE_ARTWORK_PROXY=

# Legacy: same-origin Firebase Function proxy (needs Blaze — not used in default setup)
# VITE_FIREBASE_ITUNES_PROXY=true
