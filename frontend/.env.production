# Free Firebase Hosting (Spark): production build uses Apple iTunes directly.
# Do not set VITE_FIREBASE_ITUNES_PROXY (that required paid Cloud Functions).
#
# If search/covers fail after deploy, use free Cloudflare Worker:
#   cd frontend && npx wrangler deploy
# Then add to .env.production.local (not committed):
#   VITE_ITUNES_API_BASE=https://YOUR_SUBDOMAIN.workers.dev
#   VITE_ARTWORK_PROXY=https://YOUR_SUBDOMAIN.workers.dev/image
